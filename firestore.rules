rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Configuración del sitio:
    //  - Cualquiera puede LEER (la web pública la necesita)
    //  - Solo un usuario autenticado (Yezubey) puede ESCRIBIR
    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Solicitudes de cotización:
    //  - Cualquiera puede CREAR (el formulario público)
    //  - Solo autenticado puede LEER, ACTUALIZAR y BORRAR (el panel)
    match /solicitudes/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
